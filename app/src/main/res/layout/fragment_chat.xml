<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chatRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="4dp"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="@color/transparent"
            android:elevation="4dp"
            android:baselineAligned="false"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Сообщение..."
                android:textColor="@color/textPrimary"
                android:textSize="14sp"
                android:inputType="textMultiLine"
                android:background="@drawable/frame_secondary"
                android:padding="12dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:maxLines="4" />

            <ImageButton
                android:id="@+id/attachButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/attach_image"
                android:background="@drawable/frame_done"
                android:scaleType="fitCenter"
                android:padding="4dp"
                android:contentDescription="Отправить" />
            <ImageButton
                android:id="@+id/sendButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/send_message"
                android:background="@drawable/frame_done"
                android:scaleType="fitCenter"
                android:padding="4dp"
                android:contentDescription="Отправить" />
        </LinearLayout>


    </LinearLayout>

    <!-- Кастомная кнопка "В конец списка" -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnScrollToBottom"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:layout_gravity="bottom|end"
        android:visibility="gone"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/primary"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackgroundBorderless">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/button_scroll"
            android:contentDescription="Перейти в конец списка" />
    </androidx.cardview.widget.CardView>

</FrameLayout>