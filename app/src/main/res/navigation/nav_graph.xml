<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/LoginFragment">

    <fragment
        android:id="@+id/LoginFragment"
        android:name="com.foretti.challengevorot.auth.LoginFragment"
        android:label=""
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_registration"
            app:destination="@id/RegistrationFragment" />
        <action
            android:id="@+id/action_login_to_profile"
            app:destination="@id/ProfileWithRoomFragment" />
    </fragment>
    <fragment
        android:id="@+id/RegistrationFragment"
        android:name="com.foretti.challengevorot.auth.RegistrationFragment"
        android:label=""
        tools:layout="@layout/fragment_registration">
        <action
            android:id="@+id/action_registration_to_login"
            app:destination="@id/LoginFragment" />
        <action
            android:id="@+id/action_registration_to_profile"
            app:destination="@id/ProfileWithRoomFragment" />
    </fragment>
    <fragment
        android:id="@+id/ProfileWithRoomFragment"
        android:name="com.foretti.challengevorot.profile.ProfileWithRoomFragment"
        android:label=""
        tools:layout="@layout/fragment_profile_with_room" />
    <fragment
        android:id="@+id/ProfileWithoutRoomFragment"
        android:name="com.foretti.challengevorot.profile.ProfileWithoutRoomFragment"
        android:label=""
        tools:layout="@layout/fragment_profile_without_room" />
    <fragment
        android:id="@+id/RotationFragment"
        android:name="com.foretti.challengevorot.rotation.RotationFragment"
        android:label=""
        tools:layout="@layout/fragment_rotation" />
    <fragment
        android:id="@+id/WheelFragment"
        android:name="com.foretti.challengevorot.wheel.WheelFragment"
        android:label=""
        tools:layout="@layout/fragment_wheel" />
    <fragment
        android:id="@+id/MarketFragment"
        android:name="com.foretti.challengevorot.market.MarketFragment"
        android:label=""
        tools:layout="@layout/fragment_market" />
    <fragment
        android:id="@+id/ReviewsFragment"
        android:name="com.foretti.challengevorot.reviews.ReviewsFragment"
        android:label=""
        tools:layout="@layout/fragment_reviews" />

</navigation>
